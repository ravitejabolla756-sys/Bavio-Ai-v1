{
  "info": {
    "_postman_id": "7fa72591-ec5a-45c1-90a6-c95698b6719e",
    "name": "Bavio-Global",
    "description": "REST API endpoints collection for the multi-country Bavio Voice AI platform.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Onboarding & Auth",
      "item": [
        {
          "name": "Signup User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"raj@realestates.com\",\n  \"password\": \"secure123\",\n  \"business_name\": \"Raj Properties\",\n  \"business_phone\": \"7569960503\",\n  \"industry\": \"real_estate\",\n  \"country_code\": \"IN\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/signup",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "signup"
              ]
            },
            "description": "Registers a new business client, auto-detects country, and establishes default subscription parameters, returning a JWT authentication token."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Pricing & Billing",
      "item": [
        {
          "name": "Get Pricing",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/pricing?country=IN",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "pricing"
              ],
              "query": [
                {
                  "key": "country",
                  "value": "IN",
                  "description": "ISO 2-letter country code (IN, US, GB, AU, AE)"
                }
              ]
            },
            "description": "Retrieves the country-specific pricing tiers and features in the regional currency."
          },
          "response": []
        },
        {
          "name": "Charge Subscription",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{auth_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"plan\": \"growth\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/billing/charge",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "billing",
                "charge"
              ]
            },
            "description": "Simulates payment and charging for a regional SaaS subscription plan in the user's localized currency."
          },
          "response": []
        },
        {
          "name": "Get Subscription Status",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{auth_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/subscription",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "subscription"
              ]
            },
            "description": "Fetches active plan metadata, cycle dates, and call minutes limit/usage."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Telephony & Numbers",
      "item": [
        {
          "name": "Assign Virtual Number",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{auth_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"country_code\": \"IN\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/numbers/assign",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "numbers",
                "assign"
              ]
            },
            "description": "Routes number provisioning requests based on country (Exotel for IN, Twilio for US/GB/AU/AE) and assigns a virtual line."
          },
          "response": []
        },
        {
          "name": "Get Call Logs",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{auth_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/calls?limit=50&offset=0",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "calls"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "50",
                  "description": "Pagination limit"
                },
                {
                  "key": "offset",
                  "value": "0",
                  "description": "Pagination offset"
                }
              ]
            },
            "description": "Retrieves the call transcript logs and regional billing charges for the authenticated business."
          },
          "response": []
        }
      ]
    }
  ],
