{
  "incoming_call": {
    "description": "Triggered when an incoming call starts. Sent from Exotel as POST request.",
    "method": "POST",
    "headers": {
      "Content-Type": "application/x-www-form-urlencoded",
      "X-Exotel-Signature": "computed_hmac_sha256_hash_here"
    },
    "body": {
      "MessageType": "Inbound",
      "CallSid": "call_exotel_test_123",
      "From": "+919999123456",
      "To": "+918080999999",
      "Called": "+918080999999"
    }
  },
  "call_ended": {
    "description": "Triggered when a call terminates. Updates call duration and costs in DB.",
    "method": "POST",
    "headers": {
      "Content-Type": "application/x-www-form-urlencoded",
      "X-Exotel-Signature": "computed_hmac_sha256_hash_here"
    },
    "body": {
      "CallSid": "call_exotel_test_123",
      "Status": "completed",
      "CallDuration": "120",
      "Cost": "10.50"
    }
  },
  "recording_ready": {
    "description": "Triggered when a call recording becomes available. Updates recording URL in DB.",
    "method": "POST",
    "headers": {
      "Content-Type": "application/x-www-form-urlencoded",
      "X-Exotel-Signature": "computed_hmac_sha256_hash_here"
    },
    "body": {
      "CallSid": "call_exotel_test_123",
      "RecordingUrl": "https://exotel.com/recordings/rec_123.mp3"
    }
  }
}
