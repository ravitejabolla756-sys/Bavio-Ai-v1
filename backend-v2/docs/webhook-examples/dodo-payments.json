{
  "payment_success": {
    "description": "Triggered when a Dodo Payment succeeds. Automatically activates/renews subscription plans.",
    "method": "POST",
    "headers": {
      "Content-Type": "application/json",
      "X-Dodo-Signature": "computed_dodo_signature_here"
    },
    "body": {
      "event": "payment.success",
      "subscription_id": "sub_mock_123",
      "amount": 1999,
      "currency": "INR"
    }
  },
  "payment_failed": {
    "description": "Triggered when a Dodo Payment fails. Sets subscription status to failed.",
    "method": "POST",
    "headers": {
      "Content-Type": "application/json",
      "X-Dodo-Signature": "computed_dodo_signature_here"
    },
    "body": {
      "event": "payment.failed",
      "subscription_id": "sub_mock_123",
      "amount": 1999,
      "currency": "INR"
    }
  }
}
