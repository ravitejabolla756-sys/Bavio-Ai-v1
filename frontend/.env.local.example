# ════════════════════════════════════════════
#  Bavio Frontend — Environment Variables
#  Copy this to .env.local and fill in values.
# ════════════════════════════════════════════

# Next.js rewrites /api/* → BACKEND_URL/*
# Local dev: http://localhost:5000
# Production: your Railway backend URL
BACKEND_URL=http://localhost:5000

# Supabase (public keys — safe for client-side)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon_key>

# Not needed for Next.js proxy pattern (kept for legacy reference)
# NEXT_PUBLIC_API_URL=/api
